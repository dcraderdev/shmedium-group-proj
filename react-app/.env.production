# CRA build-time settings for production

# Raise the threshold above which images are emitted as separate hashed files
# instead of being base64-inlined into JS chunks.
# Default is 10000 (10 KB); setting to 4096 keeps tiny SVG icons inlined
# (all are < 4 KB) while emitting the profile PNGs (open-book: 6.3 KB,
# fountain-pen: 9.6 KB) and store badges (AppleStore: 4.9 KB, PlayStore: 7.2 KB)
# as separately cached files — removes ~21 KB from the main bundle.
IMAGE_INLINE_SIZE_LIMIT=4096
