{
  "version": 2,
  "buildCommand": "CI=false NODE_OPTIONS=--openssl-legacy-provider DISABLE_ESLINT_PLUGIN=true npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://shmedium-api.fly.dev/api/$1"
    },
    {
      "src": "/static/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    }
  ]
}
