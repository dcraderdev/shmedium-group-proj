# Shmedium environment variables
# Copy to `.env` and fill in real values. Do NOT commit the populated .env.

# --- Flask ---
FLASK_APP=app
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# --- Database ---
# Local dev (SQLite): sqlite:///dev.db
# Production (Supabase/Render Postgres): postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///dev.db

# Postgres schema name (snake_case). Used by Alembic/SQLAlchemy in prod.
# Leave commented for SQLite dev.
# SCHEMA=shmedium_schema

# --- AWS S3 (story image uploads) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# --- React frontend ---
# This var actually belongs in react-app/.env (not root). Documented here for completeness.
# In dev, CRA proxies /api to localhost:5000 via package.json#proxy — no value needed.
# In prod (split deploy), set to the deployed Flask URL.
REACT_APP_BASE_URL=http://localhost:5000
